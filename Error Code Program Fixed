#Error Code Program Fixed
amount = eval(input("Give me a number: "))
stop = eval(input("When do you want me to stop: "))
step = 2

if amount % 2:
    while stop > 0:
        stop -= 1
        amount = amount ** step
        print(amount)
elif amount % 3:
    while stop > 0:
        stop -= 1
        amount = amount * step
        print(amount)
else:
    while stop > 0:
        stop -= 1
        amount = amount / step
